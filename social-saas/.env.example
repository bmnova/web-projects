# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# If uploads fail with "bucket does not exist", set the real GCS id (often project-id.appspot.com):
# FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Required for server-side approval video upload (bypasses browser → Storage CORS on localhost).
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Optional: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Token Encryption (32 byte hex key — openssl rand -hex 32 ile üret)
TOKEN_ENCRYPTION_KEY=

# Reddit OAuth
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REDIRECT_URI=http://localhost:3000/api/oauth/reddit/callback

# Google / YouTube OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/oauth/google/callback

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/oauth/tiktok/callback

# Meta / Instagram OAuth
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/oauth/instagram/callback

# Gemini AI
GEMINI_API_KEY=

# Set to true or 1 to skip monthly AI quota checks (local / staging only; do not enable in production).
# DISABLE_AI_QUOTA=true

# Video: mock mode skips Veo, uses random sample MP4s (no usage for those clips).
# next dev: enabled via committed .env.development — or set here / on the host.
# Vercel Preview: mock is on by default; set MOCK_VIDEO_GENERATION=false to use real Veo.
# Optional: MOCK_VIDEO_SAMPLE_URLS=https://a.mp4,https://b.mp4
MOCK_VIDEO_GENERATION=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Paddle Billing ─────────────────────────────────────────────────────────────
# Environment: sandbox | production
NEXT_PUBLIC_PADDLE_ENV=sandbox
# Client token (Paddle Dashboard → Developer Tools → Authentication)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Webhook secret (Paddle Dashboard → Notifications → Webhook endpoint)
PADDLE_WEBHOOK_SECRET=
# Price IDs for each plan (Paddle Dashboard → Catalog → Prices)
NEXT_PUBLIC_PADDLE_PRICE_STARTER=pri_
NEXT_PUBLIC_PADDLE_PRICE_PRO=pri_
NEXT_PUBLIC_PADDLE_PRICE_AGENCY=pri_
PADDLE_PRICE_STARTER=pri_
PADDLE_PRICE_PRO=pri_
PADDLE_PRICE_AGENCY=pri_
